    "import matplotlib.pyplot as plt\n",
    "\n",
    "# 1. Získání Top 5 barev pro každou dekádu (podle počtu výskytů)\n",
    "top_5_raw = (df.explode('Palette')\n",
    "             .groupby(['Decade', 'Palette'])\n",
    "             .size()\n",
    "             .reset_index(name='Count'))\n",
    "\n",
    "top_5_raw = (top_5_raw.sort_values(['Decade', 'Count'], ascending=[True, False])\n",
    "             .groupby('Decade')\n",
    "             .head(5))\n",
    "\n",
    "# 2. Pivot tabulka pro přípravu grafu\n",
    "plot_data = top_5_raw.pivot(index='Decade', columns='Palette', values='Count').fillna(0)\n",
    "\n",
    "# 3. NORMALIZACE NA 100 % (každý řádek vydělíme jeho součtem)\n",
    "plot_data_percent = plot_data.div(plot_data.sum(axis=1), axis=0) * 100\n",
    "\n",
    "# 4. Vykreslení\n",
    "ax = plot_data_percent.plot(kind='bar', stacked=True, figsize=(15, 8), width=0.8, edgecolor='black')\n",
    "\n",
    "# 5. Aplikace barev a přidání popisků\n",
    "for i, container in enumerate(ax.containers):\n",
    "    rgb_tuple = plot_data_percent.columns[i]\n",
    "    normalized_rgb = tuple(c/255 for c in rgb_tuple)\n",
    "    hex_code = '#%02x%02x%02x' % rgb_tuple\n",
    "    \n",
    "    # Nastavení barvy segmentu\n",
    "    plt.setp(container, color=normalized_rgb)\n",
    "    \n",
    "    # Výběr barvy textu pro kontrast\n",
    "    text_color = 'white' if (sum(rgb_tuple)/3) < 128 else 'black'\n",
    "    \n",
    "    # Vytvoření popisků (zobrazíme pouze u segmentů větších než 5 %)\n",
    "    labels = [f\"{hex_code}\\n{v:.1f}%\" if v > 5 else \"\" for v in container.datavalues]\n",
    "    \n",
    "    ax.bar_label(container, labels=labels, label_type='center', \n",
    "                 fontsize=9, color=text_color, fontweight='bold')\n",
    "\n",
    "plt.title('Relativní zastoupení Top 5 barev v rámci dekád (100% Stacked)', fontsize=16)\n",
    "plt.ylabel('Podíl na Top 5 barvách (%)', fontsize=12)\n",
    "plt.xlabel('Dekáda', fontsize=12)\n",
